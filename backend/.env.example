# ─── PRIMARY: Claude (Anthropic) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model options (change anytime, no code changes needed):
#   claude-haiku-4-5   → ~50 credits/msg  → USE DURING DEVELOPMENT
#   claude-sonnet-4-5  → ~500 credits/msg → USE IN PRODUCTION
CLAUDE_MODEL=claude-haiku-4-5

# ─── FALLBACK: Groq (free, fast) ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ─── Search ───────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ─── App ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
MEMORY_DB_PATH=./jarvis_memory.db
