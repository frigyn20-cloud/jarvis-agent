# ─── PRIMARY: Claude (Anthropic) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model options (change anytime, no code changes needed):
#   claude-haiku-4-5   → ~50 credits/msg  → USE DURING DEVELOPMENT
#   claude-sonnet-4-5  → ~500 credits/msg → USE IN PRODUCTION
CLAUDE_MODEL=claude-haiku-4-5

# ─── FALLBACK: Groq (free, fast) ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# llama-3.3-70b-versatile: better instruction following (still free)
GROQ_MODEL=llama-3.3-70b-versatile

