# ─── LLM Provider: Groq (FREE, no install needed) ─────────────────────────────
# Get your free key at: https://console.groq.com
# Sign up → API Keys → Create API Key → Copy it here
GROQ_API_KEY=your_groq_api_key_here

# Available free Groq models (pick one):
# llama3-70b-8192   ← best quality (recommended)
# llama3-8b-8192    ← faster, lighter
# mixtral-8x7b-32768 ← good for long context
GROQ_MODEL=llama3-70b-8192

# ─── App settings ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
MEMORY_DB_PATH=./jarvis_memory.db
